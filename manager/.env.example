# ─────────────────────────────────────────────────────────────
# Lumen Swarm Controller — Local & Cloud Configuration
# ─────────────────────────────────────────────────────────────

# ── Gemini Vision AI API Key ──
# Required to solve unknown popups and bypass Colab freezes.
# Get a free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Telegram Notifications (C2 Admin Channel) ──
# Get token from @BotFather, and chat ID from @userinfobot
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Captcha Resolver Settings ──
# Option: Input Capsolver API key to automatically bypass 
# Google reCAPTCHAs or Turnstile checks.
CAPSOLVER_API_KEY=your-capsolver-api-key-here

# ── Proxy Rotator ──
# List of residential HTTP proxies (comma separated IP:PORT:USER:PASS)
# Example: 185.122.12.33:8080:usr12:pwd34,91.211.34.2:8080
PROXY_LIST=
